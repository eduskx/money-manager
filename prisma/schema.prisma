// Prisma-Schema — hier definierst du, wie deine Datenbank aussieht.
// Nach Änderungen: `npx prisma migrate dev --name <beschreibung>` ausführen.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Zwei Adressen zur SELBEN Datenbank – das ist kein Fehler:
  //
  // url       = der Neon-Pooler („-pooler" im Hostnamen). Die App läuft auf
  //             Vercel als Serverless-Funktion, und die baut pro Anfrage eine
  //             neue Verbindung auf. Direkt gemessen: 238 ms Verbindungsaufbau
  //             gegenüber 21 ms für eine Abfrage auf offener Verbindung. Der
  //             Pooler hält die Verbindungen bereit.
  //
  // directUrl = die direkte Adresse, ohne Pooler. NUR für die Prisma-CLI:
  //             `migrate` und `db push` ändern das Schema und brauchen dafür
  //             eine echte, eigene Sitzung – über den Pooler schlägt das fehl.
  //             Die App selbst benutzt diese Adresse nie.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Die gewählte Farbwelt der Oberfläche. Der Wert landet als data-palette auf
// <html>; welche Farben dahinterstecken, steht ausschließlich in globals.css.
// Hell/Dunkel ist davon unabhängig (dark-Klasse) – jede Welt hat beide Modi.
enum Palette {
  GRAPHIT
  INDIGO
  MARINE
  SALBEI
  PFLAUME
  SAND
  ROSE
}

// Ein Benutzerkonto. Das Passwort wird niemals im Klartext gespeichert,
// sondern nur als bcrypt-Hash (siehe passwordHash).
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  // Gast-Konto: per Klick angelegt, ohne Registrierung, mit Beispieldaten
  // gefüllt. Wird nach GUEST_TTL_DAYS (src/lib/guest.ts) automatisch gelöscht.
  // E-Mail und Passwort sind Zufallswerte und für den Gast nicht nutzbar –
  // deshalb sperren die Profil-Actions diese Felder für ihn.
  isGuest      Boolean  @default(false)
  // Soll der Restbetrag eines Monats als „Vormonat" in den nächsten fließen?
  // Aus = jeder Monat steht für sich, die Vormonat-Zeile verschwindet.
  //
  // Liegt am User und nicht an der Vorlage, obwohl der Schalter dort sitzt:
  // Es ist eine Regel fürs Rechnen, kein Inhalt der Vorlage – „Vorlage leeren"
  // darf sie nicht mitreißen. Nicht nullbar wie `palette`, weil es hier kein
  // „nie gewählt" braucht: An ist die sinnvolle Voreinstellung, und wer sie
  // ausschaltet, meint genau das.
  carryOver    Boolean  @default(true)
  // Farbwelt der Oberfläche. null = der Nutzer hat noch nie eine gewählt –
  // dann gilt DEFAULT_PALETTE aus src/lib/palette.ts. Bewusst nullbar statt
  // mit DB-Default: Nur so bleibt „nie gewählt" von „genau diese Farbe
  // gewählt" unterscheidbar, und der Standard lässt sich später an genau
  // einer Stelle im Code ändern.
  palette      Palette?
  // Welche Blöcke der Nutzer eingeklappt hat – gespeichert als Liste von
  // Schlüsseln (z. B. "income", "saldo" oder die id einer Ausgaben-Spalte bzw.
  // eines Sparkonto-Blocks). Bewusst nur die EINGEKLAPPTEN: Fehlt ein Schlüssel,
  // ist der Block offen – das ist der Normalfall und braucht keinen Eintrag.
  // Verwaiste Schlüssel (gelöschte Spalte/Block) schaden nicht, sie werden
  // einfach ignoriert.
  collapsed    String[] @default([])
  createdAt    DateTime @default(now())

  months          Month[]
  savingsAccounts SavingsAccount[]

  // Für das Aufräumen abgelaufener Gäste (siehe deleteExpiredGuests).
  @@index([isGuest, createdAt])
}

// Grober Abschnitt eines Eintrags. Einnahmen und Abzüge sind feste Blöcke;
// Ausgaben sind flexibel: welche Spalte gemeint ist, steht in Entry.columnId.
enum Section {
  INCOME // Einnahmen
  EXPENSE // Ausgaben – die konkrete Spalte steht in Entry.columnId
  RUECKLAGE // Abzüge unter dem Saldo (z. B. Tagesgeld, ETF)
}

// Ein Budget-Monat ODER die Vorlage (isTemplate = true). Beide sind nur
// Container für Einträge; die Vorlage hat kein Jahr/Monat (year/month = null)
// und dient als Grundlage für jeden neuen Monat.
model Month {
  id         String   @id @default(cuid())
  year       Int? // null => Vorlage
  month      Int? // 1..12, null => Vorlage
  isTemplate Boolean  @default(false)
  createdAt  DateTime @default(now())

  userId  String
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries Entry[]
  columns ExpenseColumn[]

  // Verhindert doppelte echte Monate. Für die Vorlage (year/month = null)
  // greift der Constraint in Postgres nicht – dort sorgt die App-Logik dafür,
  // dass pro User nur eine Vorlage existiert.
  @@unique([userId, year, month])
  @@index([userId])
}

// Eine einzelne Zeile in einem Block, z. B. „Miete – 451,00 €".
model Entry {
  id        String   @id @default(cuid())
  section   Section
  label     String
  amount    Decimal  @db.Decimal(12, 2)
  // Optionale Rechenformel (z. B. „=60+30"). Wird beim Bearbeiten wieder
  // angezeigt; beim Verlassen des Feldes zeigt die App nur das Ergebnis.
  formula   String?
  position  Int      @default(0) // Reihenfolge innerhalb des Abschnitts
  createdAt DateTime @default(now())

  monthId String
  month   Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)

  // Nur bei section = EXPENSE gesetzt: die Ausgaben-Spalte, zu der die Zeile
  // gehört. Wird die Spalte gelöscht, verschwinden ihre Zeilen mit (Cascade).
  columnId String?
  column   ExpenseColumn? @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([columnId])
  @@index([monthId])
}

// Eine frei benennbare Ausgaben-Spalte eines Monats (oder der Vorlage), z. B.
// „Fixkosten" oder „Einkäufe / Essen / Leben". Ein neuer Monat/eine neue
// Vorlage startet mit genau einer Spalte („Fixkosten"); der Nutzer kann bis zu
// MAX_EXPENSE_COLUMNS (5) Spalten anlegen, umbenennen und löschen.
model ExpenseColumn {
  id        String   @id @default(cuid())
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  monthId String
  month   Month   @relation(fields: [monthId], references: [id], onDelete: Cascade)
  entries Entry[]

  @@index([monthId])
}

// -----------------------------------------------------------------------------
// Tagesgeld-Seite (Phase 2)
// -----------------------------------------------------------------------------

// Art eines Tagesgeld-Blocks. Die ersten drei sind Standardblöcke (einer je
// User); CUSTOM sind frei erstell-/löschbare Blöcke (z. B. ETF, Aktien, Krypto),
// die den Saldo NICHT beeinflussen.
enum TagesgeldKind {
  EINNAHMEN // pro Jahr, Einnahmen + Zinsen
  AUSGABEN // Gesamtausgaben des Kontos
  ZURUECKGELEGT // zurückgelegte Beträge (Urlaub, Geschenke)
  CUSTOM // frei angelegte Blöcke, saldoneutral
}

// Ein Sparkonto (z. B. „Tagesgeld"). Jeder User hat mindestens eins; bis zu
// MAX_SAVINGS_ACCOUNTS (5) sind möglich. Die Übersicht liegt unter
// /dashboard/sparkonten, das Konto selbst unter /dashboard/sparkonten/[id].
model SavingsAccount {
  id        String   @id @default(cuid())
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks TagesgeldBlock[]

  @@index([userId])
}

model TagesgeldBlock {
  id        String           @id @default(cuid())
  kind      TagesgeldKind
  name      String
  position  Int              @default(0)
  createdAt DateTime         @default(now())
  entries   TagesgeldEntry[]

  accountId String
  account   SavingsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model TagesgeldEntry {
  id        String   @id @default(cuid())
  label     String
  amount    Decimal  @db.Decimal(12, 2)
  formula   String? // optionale Rechenformel, analog zu Entry.formula
  year      Int? // nur für EINNAHMEN relevant (Jahresfilter); sonst null
  position  Int      @default(0)
  createdAt DateTime @default(now())

  blockId String
  block   TagesgeldBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
}
