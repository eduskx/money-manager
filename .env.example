# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.
# ".env" wird NICHT ins Git-Repo eingecheckt (siehe .gitignore).

# Neon Postgres Connection-String (aus dem Neon-Dashboard).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Zufälliges Secret für Auth.js. Neu erzeugen mit:  npx auth secret
# (oder:  node -e "console.log(require('crypto').randomBytes(33).toString('base64'))")
AUTH_SECRET="hier-ein-langes-zufaelliges-secret"
